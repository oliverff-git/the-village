{
"compilerOptions": {
"target": "ES2022",
"lib": ["DOM", "ES2022"],
"jsx": "preserve",
"module": "ESNext",
"moduleResolution": "Bundler",
"resolveJsonModule": true,
"strict": true,
"allowJs": false,
"noEmit": true,
"esModuleInterop": true,
"baseUrl": ".",
"paths": { "@/": ["src/"] },
"types": ["@types/node"]
},
"include": ["next-env.d.ts", "src//*.ts", "src//*.tsx"],
"exclude": ["node_modules"]
}
